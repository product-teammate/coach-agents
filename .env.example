# Global environment template. Copy to .env and fill in per-agent values.

# Claude Code CLI authentication (optional — CLI can also use your logged-in session).
# CLAUDE_CODE_OAUTH_TOKEN=

# Stub mode: when set to 1, the claude-code brain returns canned responses
# instead of spawning the `claude` CLI. Useful for CI and smoke tests.
# COACH_BRAIN_STUB=0

# Example per-agent Telegram token. The env_prefix is set in agent.yaml.
# For env_prefix: TELEGRAM_EXAMPLE_
# TELEGRAM_EXAMPLE_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_EXAMPLE_OWNER_ID=123456789

# GitHub token used by quiz-maker / flashcard-deck to publish gists.
# GITHUB_TOKEN=
