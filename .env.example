# Global environment template. Copy to .env and fill in per-agent values.

# ==========
# Claude Code
# ==========
# Phase 1 uses the `claude` CLI's logged-in session directly, so this is
# optional. Set only if you want to override with an OAuth token.
# CLAUDE_CODE_OAUTH_TOKEN=

# ==========
# Slack (per agent, env_prefix matches agent.yaml)
# ==========
# English coach (Ava)
SLACK_ENGLISH_BOT_TOKEN=xoxb-...
SLACK_ENGLISH_APP_TOKEN=xapp-...

# Playwright coach (Rook)
SLACK_PLAYWRIGHT_BOT_TOKEN=xoxb-...
SLACK_PLAYWRIGHT_APP_TOKEN=xapp-...

# ==========
# Telegram (Phase 1 also supported — one or both channels)
# ==========
# TELEGRAM_ENGLISH_BOT_TOKEN=
# TELEGRAM_PLAYWRIGHT_BOT_TOKEN=

# ==========
# Dev / testing
# ==========
# COACH_BRAIN_STUB=1   # bypass claude CLI; echo stubbed response (for smoke test)
# COACH_ONLY_AGENT=english-coach   # runtime filters to one agent

# GitHub token used by quiz-maker / flashcard-deck (the `gh` CLI's own
# auth is preferred; this is only needed in bare environments).
# GITHUB_TOKEN=
